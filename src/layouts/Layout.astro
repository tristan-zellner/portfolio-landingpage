---
import { Font } from "astro:assets";
import faviconSrc from "@/assets/favicon.svg";
import { PORTFOLIO } from "@/data/portfolio";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = PORTFOLIO.meta.title,
  description = PORTFOLIO.meta.description,
} = Astro.props;

const siteUrl = "https://tristanzellner.de";
const ogImage = `${siteUrl}/portrait.jpg`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Tristan Zellner",
  url: siteUrl,
  image: ogImage,
  jobTitle: [
    "CTO",
    "Chief Technology Officer",
    "Head of Software Development",
    "Leitung Softwareentwicklung",
  ],
  description:
    "CTO, Chief Technology Officer und Head of Software Development (Leitung Softwareentwicklung) aus Münster mit über 10 Jahren Erfahrung in technischer Führung und Full-Stack-Entwicklung.",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Münster",
    addressRegion: "Nordrhein-Westfalen",
    addressCountry: "DE",
  },
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "FH Münster",
  },
  sameAs: [
    PORTFOLIO.contact.linkedinUrl,
    PORTFOLIO.contact.githubUrl,
    PORTFOLIO.contact.xingUrl,
  ],
  knowsAbout: [
    "Software Engineering",
    "Technical Leadership",
    "Engineering Management",
    "Ruby on Rails",
    "Full-Stack Development",
    "SaaS",
  ],
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="sh2VqOC4RtkKeltVfvY56hdKfY4QPupYaEYUNrt1yAU" />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" type="image/svg+xml" href={faviconSrc.src} />

    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="profile:first_name" content="Tristan" />
    <meta property="profile:last_name" content="Zellner" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-jetbrains-mono" preload />
  </head>
  <body>
    <div class="portfolio-shell">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  @import "../styles/tokens.css";

  *, *::before, *::after {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  html, body {
    margin: 0;
    padding: 0;
    background: var(--color-paper);
  }

  body {
    font-family: var(--font-sans);
    font-feature-settings: "ss01";
    color: var(--color-ink);
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }

  .portfolio-shell {
    max-width: var(--max-width);
    margin: 0 auto;
    background: var(--color-paper);
    box-shadow: 0 0 80px rgba(0, 0, 0, 0.06);
    position: relative;
  }

  /* Paper texture overlay */
  .portfolio-shell::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(rgba(0, 0, 0, 0.025) 1px, transparent 1px);
    background-size: 3px 3px;
    opacity: 0.7;
    z-index: 0;
  }
</style>
