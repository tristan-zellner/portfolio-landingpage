---
import { PORTFOLIO } from "@/data/portfolio";

const { projects } = PORTFOLIO;
const s = PORTFOLIO.ui.sections.projects;
---

<section class="section" id="projekte">
  <div class="section-head">
    <h2><span class="num">03</span>{s.title}</h2>
    <div class="meta">{projects.length} {s.metaUnit}</div>
  </div>

  <div class="project-list">
    {
      projects.map((p) => (
        <div class="project">
          <div class="project-period">
            <span class="period-label">{p.period}</span>
          </div>
          <div class="project-main">
            <h3>{p.title}</h3>
            <ul>
              {p.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .section {
    padding: var(--space-8) var(--page-padding);
    position: relative;
    z-index: 1;
    border-bottom: var(--border-thin);
  }

  .section-head {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-2);
    border-bottom: var(--border-thick);
  }

  h2 {
    font-size: var(--text-6xl);
    line-height: 1;
    letter-spacing: -0.035em;
    font-weight: 600;
    margin: 0;
  }

  .num {
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 400;
    color: var(--color-accent);
    vertical-align: top;
    margin-right: var(--space-2);
    letter-spacing: 0.1em;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-ink-3);
  }

  .project-list {
    display: grid;
    gap: 0;
  }

  .project {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--space-6);
    padding: 36px 0;
    border-top: var(--border-thin);
  }

  .project:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .project:last-child {
    border-bottom: var(--border-thin);
  }

  .project-period {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-ink);
    padding-top: 8px;
  }

  .period-label {
    font-size: var(--text-3xl);
    display: block;
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  h3 {
    font-size: var(--text-4xl);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 600;
    margin: 0 0 var(--space-3);
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-1);
    max-width: 820px;
  }

  li {
    font-size: var(--text-base);
    color: var(--color-ink-2);
    line-height: 1.55;
    display: grid;
    grid-template-columns: 22px 1fr;
  }

  li::before {
    content: "—";
    color: var(--color-ink-4);
  }
</style>
